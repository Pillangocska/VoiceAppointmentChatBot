# Local runtime configuration for the voice chatbot.
#
# Copy this file to ``config.yaml`` (gitignored) and fill in the values
# you want to override. Every section below is optional: missing keys
# fall back to the defaults defined in src/voiceappointmentchatbot/config.py.

huggingface:
  # Personal access token from https://huggingface.co/settings/tokens.
  # Lifts anonymous rate limits and lets you pull gated models.
  token: ""

device:
  # Force a specific device. Leave as "auto" to detect CUDA via ctranslate2.
  # Allowed values: auto, cuda, cpu.
  override: "auto"

whisper:
  # Override the model selected per device. See faster-whisper docs for
  # the full list (tiny, base, small, medium, large-v3, distil-large-v3, ...).
  gpu_model: "large-v3"
  cpu_model: "small"

audio:
  # Sample rate in Hz. Whisper expects 16000.
  sample_rate: 16000

output:
  # Directory where appointment JSON files are written.
  dir: "output"

anthropic:
  # API key from https://console.anthropic.com/. Required for the
  # week-2 dialogue manager; leave empty to disable LLM calls (handy
  # for tests that mock the client).
  api_key: ""
  # Claude model identifier. Haiku 4.5 is the default — fast and cheap.
  model: "claude-haiku-4-5-20251001"
  # Maximum response length per turn.
  max_tokens: 512

# Active business domain. Must match a YAML file under domains/
# (e.g. ``vet`` or ``hairdresser``).
domain: "vet"

domains:
  # Directory containing the domain YAML and knowledge-base files.
  dir: "domains"

knowledge:
  # Sentence-Transformers model used to embed document chunks and
  # incoming questions. The default is multilingual (EN+HU) and runs
  # comfortably on CPU.
  embedding_model: "sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2"
  # Number of chunks returned per knowledge-base query.
  top_k: 3
